# 复制到项目根目录并重命名为 .env：
#   cp .env.example .env
#
# run_workflow.sh 会加载 .env；缺失的 LLM 项可在运行时交互补全。
# 物种与组织不要写在这里，请每次运行时通过参数指定：
#   ./run_workflow.sh --species human --tissue "人肺腺癌组织"

# OpenAI 兼容接口（必填；也可运行时输入）
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini

# 可选：输出目录（也可用 ./run_workflow.sh --out）
# CELLTYPE_PIPELINE_OUT=outputs

# 可选：最终 h5ad 文件名（默认 SC_annotated.h5ad）
# OUTPUT_H5AD_NAME=SC_annotated.h5ad

# 可选：输入 h5ad 路径（也可用 ./run_workflow.sh --input）
# INPUT_H5AD=SC.h5ad
